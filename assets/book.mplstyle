# PyMC Book matplotlib style
figure.figsize: 8, 4
figure.dpi: 150
figure.facecolor: white

axes.facecolor: white
axes.grid: false
axes.spines.top: false
axes.spines.right: false
axes.labelsize: 11
axes.titlesize: 12

lines.linewidth: 1.5
lines.markersize: 5

font.size: 10

legend.frameon: false
legend.fontsize: 9

savefig.bbox: tight
savefig.dpi: 150
